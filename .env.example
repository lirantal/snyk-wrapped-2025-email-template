# Mailgun API Configuration (Required)
# Get these from your Mailgun dashboard: https://app.mailgun.com/
MAILGUN_API_KEY=your_mailgun_private_api_key_here
MAILGUN_DOMAIN=snyk.io
MAILGUN_FROM_EMAIL=noreply@snyk.io
MAILGUN_FROM_NAME=Snyk Team

# Email Configuration (Optional)
# The year for the wrapped statistics (defaults to current year if not set)
EMAIL_YEAR=2025

# Custom email subject line (defaults to "Your {year} Snyk Wrapped - See your security stats")
EMAIL_SUBJECT=Your 2025 Snyk Wrapped - See your security stats

# CSV Configuration (Optional)
# Path to the recipients CSV file (defaults to ./recipients.csv)
# CSV_PATH=./path/to/your/recipients.csv

# Social Sharing URLs (Optional)
# LinkedIn share URL for social sharing buttons in email
LINKEDIN_SHARE_URL=https://www.linkedin.com/sharing/share-offsite/?url=https://snyk.io

# X/Twitter share URL for social sharing buttons in email
X_SHARE_URL=https://twitter.com/intent/tweet?url=https://snyk.io

# Unsubscribe Configuration (Optional but Recommended)
# URL for unsubscribe link. If not set, unsubscribe link will not appear in email.
# Recommended: Use Mailgun's unsubscribe handling or your own unsubscribe endpoint
# You can use Mailgun recipient variables like %recipient% for email address
UNSUBSCRIBE_URL=https://snyk.io/unsubscribe?email=%recipient%
